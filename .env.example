# 复制此文件为 .env，填入实际值（Windows 下用 set 命令或 python-dotenv 加载）

# Anthropic API Key（必填）
ANTHROPIC_API_KEY=sk-ant-...

# 你的微信 wxid（"WeChat Files" 下的文件夹名称，例如 wxid_xxxxxxxx）
WECHAT_MY_WXID=your_wxid_here

# 监听的对话，逗号分隔（群ID 或 个人wxid）
# 群ID 格式：123456789@chatroom
# 个人格式：wxid_xxxxxxxxxx
WECHAT_WATCH_IDS=123456789@chatroom,wxid_xxxxxxxxxx

# 触发词，逗号分隔（其他人发消息含这些词时触发）
BOT_TRIGGERS=小昕,/xin

# 数据库路径（自动检测，一般不需要填）
# 默认：%USERPROFILE%\Documents\WeChat Files\<wxid>\Msg\MSG0.db
# WECHAT_DB_PATH=C:\Users\你的名字\Documents\WeChat Files\wxid_xxx\Msg\MSG0.db
# WECHAT_CONTACT_DB=C:\Users\你的名字\Documents\WeChat Files\wxid_xxx\Msg\MicroMsg.db

# SQLCipher 二进制路径（如果 sqlcipher3-binary 安装失败才需要）
# 下载地址: https://github.com/nalgeon/sqlean/releases
# SQLCIPHER_BIN=C:\sqlcipher\sqlcipher.exe

# AI 设置（可选，有默认值）
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=1500
REPLY_PREFIX=👾
MAX_HISTORY=100
