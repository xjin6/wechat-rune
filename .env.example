# 复制此文件为 .env，填入实际值
# 启动前执行：source .env

# Anthropic API Key（必填）
ANTHROPIC_API_KEY=sk-ant-...

# 你的微信 wxid（登录后在数据库路径中可以看到）
WECHAT_MY_WXID=your_wxid_here

# 监听的对话，逗号分隔（群ID 或 个人wxid）
# 群ID 格式：123456789@chatroom
# 个人格式：wxid_xxxxxxxxxx
WECHAT_WATCH_IDS=123456789@chatroom,wxid_xxxxxxxxxx

# 触发词，逗号分隔（其他人发消息含这些词时触发）
BOT_TRIGGERS=小昕,/xin

# 微信数据库路径（把 <wxid> 替换成你的 wxid，<suffix> 是wxid后面的随机字符串）
WECHAT_DB_PATH=~/Library/Containers/com.tencent.xinWeChat/Data/Documents/xwechat_files/<wxid>_<suffix>/db_storage/message/message_0.db

# AI 设置（可选，有默认值）
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=1500
REPLY_PREFIX=👾
MAX_HISTORY=50
